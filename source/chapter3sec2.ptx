<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="chp3sec2" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Uniqueness of Prime Factorization</title>

  <p> </p>

  <definition xml:id="definition-prime_factorization">
    <title>Prime Factorization</title>
    <statement>
        <p>
            A <term>prime factorization</term> of a positive integer is an expression of the integer as a product of prime numbers.
        </p>
    </statement>
  </definition>


<proposition xml:id="proposition-uniqueness_of_prime_factorization">
  <title>Uniqueness of Prime Factorization</title>
  <statement>
    <p>
      The prime factorization of a positive integer greater than 1 is unique up to the order of the factors.
    </p>
  </statement>
  <proof>
    <p>
      Coming soon...
    </p>
  </proof>
</proposition>



</section>